{
  "compilerOptions": {
    "lib": ["ES2017", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "target": "ES2017",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "allowJs": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": ["."]
}
